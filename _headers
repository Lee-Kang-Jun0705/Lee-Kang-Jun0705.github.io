# Cloudflare Pages 헤더 규칙 (dist/_headers 로 자동 복사됨)
# 진입점(sw.js/index.html)은 항상 네트워크에서 신선하게 받아 새 Service Worker 등록이 막히지 않게 한다.
# 강제 새로고침해도 옛 SW가 옛 번들을 서빙하던 문제(포탈/몬스터 미반영)를 해결.

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

# 해시 파일명 번들/에셋은 내용이 바뀌면 파일명도 바뀌므로 장기 캐시 안전
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 기본 보안 헤더 (게임 WebGL/blob 동작을 막지 않도록 CSP는 제외)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
